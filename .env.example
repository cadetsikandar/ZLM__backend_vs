# ═══════════════════════════════════════════════════════════════════════
# ZLM TEXTBOOK AUTOMATION — BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://your-frontend.vercel.app

# ── Database (Railway provides this automatically) ───────────────────────
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Redis (Railway provides this automatically) ──────────────────────────
REDIS_URL=redis://default:password@host:6379

# ── JWT (generate strong random strings) ────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-256-bit-secret-here
JWT_REFRESH_SECRET=your-256-bit-refresh-secret-here

# ── OpenAI ───────────────────────────────────────────────────────────────
# Option A: Direct env var (development only)
OPENAI_API_KEY=sk-proj-your-new-rotated-key-here
# Option B: AWS Secrets Manager (recommended for production)
# USE_AWS_SECRETS_MANAGER=true
# AWS_REGION=us-east-1
# (key stored as zlm/openai-api-key in Secrets Manager)

# ── AWS S3 ───────────────────────────────────────────────────────────────
AWS_S3_BUCKET_NAME=zlm-manuscripts-production
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-iam-access-key-id
AWS_SECRET_ACCESS_KEY=your-iam-secret-access-key

# ── GitHub (for per-book version control) ───────────────────────────────
GITHUB_TOKEN=ghp_your-personal-access-token
GITHUB_REPO_OWNER=your-github-username-or-org
GITHUB_REPO_NAME=zlm-manuscripts

# ── Admin Seed Credentials (change after first login!) ──────────────────
ADMIN_EMAIL=admin@zlm.com
ADMIN_PASSWORD=ZLM@dmin2026!

# ── Optional: Canva API (Phase 6) ───────────────────────────────────────
# CANVA_CLIENT_ID=your-canva-client-id
# CANVA_CLIENT_SECRET=your-canva-client-secret

# ── Optional: Airtable (Phase 5) ────────────────────────────────────────
# AIRTABLE_API_KEY=your-airtable-pat
# AIRTABLE_BASE_ID=your-airtable-base-id

# ── AI Generation Concurrency ────────────────────────────────────────────
# Tune these based on your OpenAI tier
CHAPTER_CONCURRENCY=3
QA_CONCURRENCY=3
TOC_CONCURRENCY=2
